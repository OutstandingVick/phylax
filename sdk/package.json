{
  "name": "@phylax/sdk",
  "version": "0.1.0",
  "description": "Zero-dependency client and CLI for Phylax execution preflights and signed risk attestations.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
