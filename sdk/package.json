  },
  "files": [
    "index.mjs",
    "index.d.ts",
    "okx-evidence.mjs",
    "okx-evidence.d.mts",
    "cli.mjs",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
